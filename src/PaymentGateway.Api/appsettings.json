{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=PaymentGateway;Username=admin;Password=password"
  },
  "ReverseProxy": {
    "Routes": {
      "merchant-route": {
        "ClusterId": "merchant-cluster",
        "Match": {
          "Path": "/api/merchant/{**remainder}"
        }
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/payment/{**remainder}"
        }
      }
    },
    "Clusters": {
      "merchant-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7001/"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7002/"
          }
        }
      }
    }
  }
}
