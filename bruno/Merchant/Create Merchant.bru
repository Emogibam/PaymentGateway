meta {
  name: Create Merchant
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/merchant
  body: json
  auth: none
}

body:json {
  {
    "name": "Acme Corp",
    "webhookUrl": "https://webhook.site/test"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("apiKey", res.body.apiKey);
  }
}
